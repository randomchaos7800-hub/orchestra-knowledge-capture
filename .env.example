# Orchestra Knowledge Capture — configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# Path to your Orchestra wiki directory (where wiki/ lives)
WIKI_DIR=/path/to/your/orchestra

# LLM — any OpenAI-compatible endpoint
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=openai/gpt-4o-mini

# ── Optional ──────────────────────────────────────────────────────────────────

# Separate model for Q&A (uses OPENAI_MODEL if not set)
# QA_MODEL=openai/gpt-4o-mini

# Per-pass model overrides (both default to OPENAI_MODEL)
# PLAN_MODEL=openai/gpt-4o-mini   # Pass 1: JSON planning (cheaper/faster)
# WRITE_MODEL=openai/gpt-4o       # Pass 2: article writing (more capable)

# Server
PORT=8080
HOST=0.0.0.0

# Knowledge base display name (shown in UI)
KB_NAME=Knowledge Base
